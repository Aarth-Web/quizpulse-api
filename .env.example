# App
APP_KEY=
APP_NAME=QuizPulse
APP_URL=http://localhost:3333
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

# Session (use memory for local API work; switch if you need persisted server sessions)
SESSION_DRIVER=memory

# Database — Lucid uses DB_*; start/env also requires PG_* — keep both in sync
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=quizpulse

PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DB_NAME=quizpulse

# Redis (required for live sessions, scores, answered-question tracking)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-development-only
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=604800

# Google OAuth (required by env schema; replace for real Google sign-in)
GOOGLE_CLIENT_ID=local-dev-placeholder
GOOGLE_CLIENT_SECRET=local-dev-placeholder
GOOGLE_CALLBACK_URL=http://localhost:3333/auth/google/callback
